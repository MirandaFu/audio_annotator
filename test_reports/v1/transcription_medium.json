    },
    {
      "start": 1903.69,
      "end": 1904.85,
      "text": "他们又跟我说一个事情"
    },
    {
      "start": 1905.54,
      "end": 1906.24,
      "text": "又跟我说"
    },
    {
      "start": 1906.84,
      "end": 1908.1,
      "text": "有跟他提吗"
    },
    {
      "start": 1908.1,
      "end": 1909.6,
      "text": "你说我现在要一个外伙的"
    },
    {
      "start": 1909.6,
      "end": 1910.54,
      "text": "然后能够"
    },
    {
      "start": 1910.54,
      "end": 1911.6,
      "text": "在里面去做台版"
    },
    {
      "start": 1911.78,
      "end": 1912.68,
      "text": "有说吗"
    },
    {
      "start": 1912.68,
      "end": 1913.84,
      "text": "我听见了"
    },
    {
      "start": 1913.84,
      "end": 1914.34,
      "text": "这个我听见了"
    },
    {
      "start": 1914.34,
      "end": 1915.68,
      "text": "我应该是跟他说了的"
    },
    {
      "start": 1915.68,
      "end": 1916.72,
      "text": "你不要应该"
    },
    {
      "start": 1917.05,
      "end": 1917.37,
      "text": "对"
    },
    {
      "start": 1917.77,
      "end": 1919.21,
      "text": "他们也想要下去"
    },
    {
      "start": 1919.21,
      "end": 1919.89,
      "text": "好难吧"
    },
    {
      "start": 1921.32,
      "end": 1922.3,
      "text": "因为这个事情"
    },
    {
      "start": 1922.3,
      "end": 1923.34,
      "text": "说白了"
    },
    {
      "start": 1923.34,
      "end": 1924.56,
      "text": "第一个跨部门了"
    },
    {
      "start": 1925.05,
      "end": 1925.65,
      "text": "第二个"
    },
    {
      "start": 1931.49,
      "end": 1932.47,
      "text": "太上了"
    },
    {
      "start": 1932.81,
      "end": 1933.97,
      "text": "包括我跟三星说的"
    },
    {
      "start": 1933.97,
      "end": 1934.97,
      "text": "也是天库起上了"
    },
    {
      "start": 1934.97,
      "end": 1935.89,
      "text": "其实欧黑那么"
    },
    {
      "start": 1935.89,
      "end": 1937.19,
      "text": "要做的事情一大堆了"
    },
    {
      "start": 1945.68,
      "end": 1981.99,
      "text": "那么下落干什么的"
    },
    {
      "start": 1981.99,
      "end": 1998.17,
      "text": "有可能顾及的"
    },
    {
      "start": 1999.08,
      "end": 2055.99,
      "text": "已经发生了"
    },
    {
      "start": 2055.99,
      "end": 2056.35,
      "text": "一切啊"
    },
    {
      "start": 2142.74,
      "end": 2143.38,
      "text": "给他找出一下"
    },
    {
      "start": 2143.62,
      "end": 2158.7,
      "text": "跟你说过的"
    },
    {
      "start": 2158.7,
      "end": 2159.64,
      "text": "我不要实际上"
    },
    {
      "start": 2160.0,
      "end": 2160.32,
      "text": "我要"
    },
    {
      "start": 2161.64,
      "end": 2201.28,
      "text": "你跟他对着驱逐"
    },
    {
      "start": 2201.28,
      "end": 2201.98,
      "text": "实际上他就知道"
    },
    {
      "start": 2300.46,
      "end": 2301.16,
      "text": "我跟我跟沈皮"
    },
    {
      "start": 2302.97,
      "end": 2303.85,
      "text": "请假提交掉了"
    },
    {
      "start": 2320.28,
      "end": 2321.54,
      "text": "我们实际上在聊的事情"
    },
    {
      "start": 2321.54,
      "end": 2322.38,
      "text": "但是第三季度"
    },
    {
      "start": 2322.38,
      "end": 2323.62,
      "text": "我们要把这东西做出来的"
    },
    {
      "start": 2326.42,
      "end": 2327.12,
      "text": "你现在看到的"
    },
    {
      "start": 2327.12,
      "end": 2346.21,
      "text": "比如说这个嘛"
    },
    {
      "start": 2346.21,
      "end": 2346.79,
      "text": "对话一条一条"
    },
    {
      "start": 2354.38,
      "end": 2354.7,
      "text": "对"
    },
    {
      "start": 2354.7,
      "end": 2355.58,
      "text": "最终办的人"
    },
    {
      "start": 2367.63,
      "end": 2368.53,
      "text": "验证完一个之后"
    },
    {
      "start": 2368.53,
      "end": 2392.29,
      "text": "马上从现在这两天"
    },
    {
      "start": 2392.29,
      "end": 2392.93,
      "text": "这么去干"
    },
    {
      "start": 2394.7,
      "end": 2395.02,
      "text": "你看"
    },
    {
      "start": 2398.37,
      "end": 2399.89,
      "text": "前几个数字里"
    },
    {
      "start": 2399.89,
      "end": 2401.15,
      "text": "行动会比较多"
    },
    {
      "start": 2405.09,
      "end": 2406.39,
      "text": "但是前面那段第二季度"
    },
    {
      "start": 2406.39,
      "end": 2407.23,
      "text": "你要给我"
    },
    {
      "start": 2407.23,
      "end": 2410.64,
      "text": "推进快再快啊"
    },
    {
      "start": 2410.64,
      "end": 2411.46,
      "text": "要跟虚拟一样"
    },
    {
      "start": 2411.46,
      "end": 2412.02,
      "text": "我这会"
    },
    {
      "start": 2412.02,
      "end": 2413.7,
      "text": "我这会已经很烦了"
    },
    {
      "start": 2415.82,
      "end": 2417.46,
      "text": "夏天本来就倒热"
    },
    {
      "start": 2417.46,
      "end": 2418.36,
      "text": "主编一副"
    },
    {
      "start": 2418.36,
      "end": 2419.02,
      "text": "我去"
    },
    {
      "start": 2419.33,
      "end": 2419.87,
      "text": "好吧"
    },
    {
      "start": 2420.83,
      "end": 2421.19,
      "text": "那"
    },
    {
      "start": 2421.19,
      "end": 2421.87,
      "text": "那先去吧"
    },
    {
      "start": 2421.87,
      "end": 2422.99,
      "text": "那先去吧"
    },
    {
      "start": 2422.99,
      "end": 2424.19,
      "text": "那李迪我们先戴上了"
    },
    {
      "start": 2424.19,
      "end": 2424.45,
      "text": "好不好"
    },
    {
      "start": 2425.03,
      "end": 2425.87,
      "text": "嗯 好的"
    },
    {
      "start": 2425.87,
      "end": 2428.85,
      "text": "那里面去啊"
    },
    {
      "start": 2428.85,
      "end": 2429.57,
      "text": "嗯 好"
    }
  ]
